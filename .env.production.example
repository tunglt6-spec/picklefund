# ============================================================
# PickleFund V2.0 — Production Environment Configuration
# Copy to .env.production and fill in all values
# NEVER commit .env.production to version control
# ============================================================

# --- Database ---
POSTGRES_DB=picklefund
POSTGRES_USER=picklefund
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://picklefund:CHANGE_ME_strong_password_here@postgres:5432/picklefund?schema=public

# --- Redis ---
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- JWT Authentication ---
JWT_SECRET=CHANGE_ME_minimum_64_char_random_string_here_use_openssl_rand_base64_64
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_another_64_char_random_string_different_from_jwt_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# --- App ---
NODE_ENV=production
PORT=3000
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# --- CORS ---
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# --- Frontend (build-time, bắt buộc) ---
# Phải trỏ đến API subdomain, KHÔNG dùng relative path /api
# Ví dụ: VITE_API_URL=https://api.your-domain.com/api
VITE_API_URL=https://api.your-domain.com/api

# --- Optional: Telegram Bot ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook

# --- Optional: Google AI ---
# GOOGLE_AI_API_KEY=

# --- Optional: Email (SMTP) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@your-domain.com

# --- Backup (optional) ---
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=ap-southeast-1
