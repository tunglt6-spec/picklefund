NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB

POSTGRES_USER=picklefund
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=picklefund

REDIS_URL=redis://:REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

JWT_SECRET=CHANGE_ME_JWT_SECRET_64_CHARS_MIN
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64_CHARS_MIN
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_REMEMBER_EXPIRES_IN=90d

APP_URL=https://app.picklefund.vn
API_URL=https://api.picklefund.vn
ALLOWED_ORIGINS=https://app.picklefund.vn,https://admin.picklefund.vn

BACKUP_RETENTION_DAYS=30

# ── AI Harness (V2.1) ──────────────────────────────────────────────────────────
# NOTE: priority / baseUrl / defaultModel / contextWindow are NOT hardcoded.
# When a provider is enabled in production, its baseUrl + apiKey are required
# or the application fails fast on boot (AIConfigService.validateConfig).
#
# LiteLLM proxy (Docker service on same network)
LITELLM_ENABLED=true
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=CHANGE_ME_LITELLM_API_KEY
LITELLM_DEFAULT_MODEL=claude-sonnet-4-6
LITELLM_PRIORITY=1
LITELLM_CONTEXT_WINDOW=200000

# OpenRouter (optional tier — disabled by default)
OPENROUTER_ENABLED=false
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_API_KEY
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o
OPENROUTER_PRIORITY=2
OPENROUTER_CONTEXT_WINDOW=128000

# Ollama local fallback (disabled by default — only for full outage)
AI_FALLBACK_TO_LOCAL=false
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=60000
OLLAMA_PRIORITY=3
OLLAMA_CONTEXT_WINDOW=32000

# AI Global Config
AI_DEFAULT_PROVIDER=litellm
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_TIMEOUT_MS=30000
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_TOP_P=1.0
AI_FALLBACK_ENABLED=true

# Retry Policy (retries 429/5xx/network only; never 4xx or client timeout)
AI_MAX_RETRIES=3
AI_RETRY_INITIAL_DELAY_MS=500
AI_RETRY_MAX_DELAY_MS=10000
AI_RETRY_BACKOFF=2
AI_RETRY_JITTER=true

# Circuit Breaker
AI_CB_FAILURE_THRESHOLD=5
AI_CB_RECOVERY_TIMEOUT_MS=60000
AI_CB_HALF_OPEN_CALLS=1
